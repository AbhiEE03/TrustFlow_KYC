# DJANGO CONFIGURATION
# Set to True for development, False for production
DJANGO_DEBUG=True
# Generate a secure random string for production
DJANGO_SECRET_KEY=your-secure-production-secret-key-here
# Comma-separated list of allowed host domains
ALLOWED_HOSTS=playto-backend-6ji4.onrender.com,127.0.0.1,localhost
# Comma-separated list of allowed CORS origin domains
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://kyc-abhi.vercel.app

# DATABASE CONFIGURATION
# Defaults to local SQLite. Provide a PostgreSQL URL in production (e.g. on Render)
# DATABASE_URL=postgres://user:password@host:port/dbname

# OBJECT STORAGE CONFIGURATION (S3 or compatible bucket like Cloudflare R2)
# If these are provided, uploads will be saved directly to the S3 bucket.
# If left empty, the application will fallback to local media file storage.
# AWS_ACCESS_KEY_ID=your-aws-access-key-id
# AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
# AWS_STORAGE_BUCKET_NAME=your-s3-bucket-name
# AWS_S3_REGION_NAME=ap-south-1
# AWS_S3_CUSTOM_DOMAIN=cdn.yourdomain.com
# AWS_S3_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
